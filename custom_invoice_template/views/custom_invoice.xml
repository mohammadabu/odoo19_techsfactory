<odoo>
    <data>
        <record id="custom_invoice_tree_list" model="ir.ui.view">
            <field name="name">Custom Invoice Tree List</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date_due']" position="after">
                    <field name="ref" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='amount_total_in_currency_signed']" position="attributes">
                    <attribute name="string">Total(Actual total)</attribute>
                </xpath>
                <xpath expr="//field[@name='amount_total_in_currency_signed']" position="after">
                    <field name="amount_residual_signed" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='amount_untaxed_in_currency_signed']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>   
